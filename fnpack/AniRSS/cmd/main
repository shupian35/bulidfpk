#!/bin/bash

LOG_FILE="${TRIM_DATA_SHARE_PATHS%%:*}/logs/ani-rss.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
APP_DIR="${TRIM_DATA_SHARE_PATHS%%:*}"
ANI_JAR="${APP_DIR}/ani-rss.jar"
RUN_MODE="$run_mode"
UI_PORT="$ui_port"
PROXY_ENABLED="$proxy_enabled"
PROXY_HOST="$proxy_host"
PROXY_PORT="$proxy_port"
MCP_ENABLED="$mcp_enabled"
SWAGGER_ENABLED="$swagger_enabled"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

configure_utf8_locale() {
    local candidate
    local selected=""
    local available=""
    local charmap="unknown"

    if command -v locale >/dev/null 2>&1; then
        available=$(locale -a 2>/dev/null || true)
        while IFS= read -r candidate; do
            case "$candidate" in
                C.UTF-8|C.utf8|en_US.UTF-8|en_US.utf8)
                    selected="$candidate"
                    break
                    ;;
            esac
        done <<< "$available"
    fi

    # Modern fnOS provides C.UTF-8/C.utf8. Keep a deterministic fallback so
    # Java does not inherit the service manager's ASCII C locale.
    if [ -z "$selected" ]; then
        selected="C.UTF-8"
    fi

    export LANG="$selected"
    export LC_ALL="$selected"
    export LC_CTYPE="$selected"

    if command -v locale >/dev/null 2>&1; then
        charmap=$(locale charmap 2>/dev/null || echo "unknown")
    fi
    log_msg "Locale: LANG=${LANG}, LC_ALL=${LC_ALL}, charmap=${charmap}"
}

get_java_cmd() {
    if [ -n "${JAVA_HOME:-}" ] && [ -x "${JAVA_HOME}/bin/java" ]; then
        echo "${JAVA_HOME}/bin/java"
        return
    fi
    if [ -x "/var/apps/java-17-openj9/target/bin/java" ]; then
        echo "/var/apps/java-17-openj9/target/bin/java"
        return
    fi
    if [ -x "/var/apps/java-17-openjdk/target/bin/java" ]; then
        echo "/var/apps/java-17-openjdk/target/bin/java"
        return
    fi
    echo ""
}

start_process() {
    if status; then
        return 0
    fi

    configure_utf8_locale

    JAVA_CMD=$(get_java_cmd)
    if [ -z "$JAVA_CMD" ]; then
        echo "未找到 Java! 请先安装 java-17-openj9 或 java-17-openjdk 应用" > "${TRIM_TEMP_LOGFILE}"
        return 1
    fi

    log_msg "Java: ${JAVA_CMD}"

    if [ "${RUN_MODE}" = "low" ]; then
        JAVA_OPTS="-Xms128m -Xmx512m"
        log_msg "低内存模式"
    else
        JAVA_OPTS="-Xms256m -Xmx1g"
        log_msg "高内存模式"
    fi

    JAVA_OPTS="${JAVA_OPTS} -Dfile.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.jnu.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.stdout.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dsun.stderr.encoding=UTF-8"
    JAVA_OPTS="${JAVA_OPTS} -Dserver.port=${UI_PORT}"

    if [ "${PROXY_ENABLED}" = "true" ]; then
        JAVA_OPTS="${JAVA_OPTS} -Dhttp.proxyHost=${PROXY_HOST} -Dhttp.proxyPort=${PROXY_PORT}"
        JAVA_OPTS="${JAVA_OPTS} -Dhttps.proxyHost=${PROXY_HOST} -Dhttps.proxyPort=${PROXY_PORT}"
        log_msg "启用 HTTP 代理: ${PROXY_HOST}:${PROXY_PORT}"
    fi

    CONFIG="CONFIG=${APP_DIR}"
    CMD="${JAVA_CMD} ${JAVA_OPTS} -D${CONFIG} -DMCP_ENABLED=${MCP_ENABLED} -DSWAGGER_ENABLED=${SWAGGER_ENABLED} -jar ${ANI_JAR}"
    log_msg "CMD = ${CMD}"
    log_msg "Starting process ..."

    cd "${APP_DIR}"
    nohup ${CMD} 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    return 0
}

stop_process() {
    log_msg "Stopping process ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            log_msg "remove pid file (process not exist)"
            return
        fi

        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 15 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/15s)"
        done

        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
        else
            log_msg "process killed gracefully"
        fi
    fi
    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then exit 0; else exit 3; fi
    ;;
*)
    exit 1
    ;;
esac